root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.yml]
end_of_line = lf
indent_style = space
indent_size = 2

[*.yaml]
end_of_line = lf
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.ps1]
indent_style = space
indent_size = 4

[*.cmd]
end_of_line = crlf
