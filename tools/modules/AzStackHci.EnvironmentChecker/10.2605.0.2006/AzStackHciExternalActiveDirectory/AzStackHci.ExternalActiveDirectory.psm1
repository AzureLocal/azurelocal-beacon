Import-LocalizedData -BindingVariable lcAdTxt -FileName AzStackHci.ExternalActiveDirectory.Strings.psd1
Import-Module $PSScriptRoot\AzStackHci.ExternalActiveDirectory.Helpers.psm1 -DisableNameChecking -Global
Import-Module $PSScriptRoot\AzStackHci.ExternalActiveDirectory.Tests.psm1 -DisableNameChecking -Global

function Invoke-AzStackHciExternalActiveDirectoryValidation
{
    <#
    .SYNOPSIS
        Perform AzStackHci External AD Validation
    .DESCRIPTION
        Perform AzStackHci External AD Validation
    .EXAMPLE
        PS C:\> Invoke-AzStackHciExternalActiveDirectoryValidation -ConfigurationJsonPath <path to deployment.json>
        PS C:\> Invoke-AzStackHciExternalActiveDirectoryValidation -ConfigurationJsonPath C:\CloudDeployment\FullEnvironment.json
        Perform validation against an external AD, using the values saved in the deployment json file
    .EXAMPLE
        PS C:\> Invoke-AzStackHciExternalActiveDirectoryValidation -BaseADDomainPath <base domain path> -HciOUName <organizational unit top-level name>
        PS C:\> Invoke-AzStackHciExternalActiveDirectoryValidation -BaseADDomainPath 'DC=v,DC=masd,DC=microsoft,DC=com' -HciOUName 'Hci001'
        Perform validation against an external AD, using the command line values
    .PARAMETER ConfigurationJsonPath
        Directory path to the deployment json file.
    .PARAMETER ADOUPath
        AD domain path that should have the organizational units for this deployment, eg OU=Hci001,OU=HciDeployments,DC=v,DC=masd,DC=stbtest,DC=microsoft,DC=com.
    .PARAMETER DomainFQDN
        Fully qualified domain name used for this HCI deployment.
    .PARAMETER NamingPrefix
        HCI deployment prefix.
    .PARAMETER ClusterName
        Secure cluster name used by deployment (eg, s-cluster).
    .PARAMETER PhysicalMachineNames
        Physical machine names used by deployment.
    .PARAMETER ActiveDirectoryServer
        Name of the Active Directory server to use for AD queries.
    .PARAMETER ActiveDirectoryCredentials
        Credentials used to access the AD server for queries.
    .PARAMETER PsSession
        Specify the PsSession(s) used to validation from. If null the local machine will be used.
    .PARAMETER PassThru
        Return PSObject result.
    .PARAMETER HardwareClass
        Hardware class: Small, Medium, or Large.
    .PARAMETER ClusterPattern
        Hardware class: Standard, Stretch, or RackAware.
    .PARAMETER OutputPath
        Directory path for log and report output.
    .PARAMETER CleanReport
        Remove all previous progress and create a clean report.
    .INPUTS
        Inputs (if any)
    .OUTPUTS
        Output (if any)
    .LINK
        https://docs.microsoft.com/en-us/azure-stack/hci/manage/use-environment-checker?tabs=active-directory
    #>
    [CmdletBinding()]
    param (


        [Parameter(Mandatory = $false, HelpMessage = "Directory path to the deployment json file")]
        [string]$ConfigurationJsonPath,

        [Parameter(Mandatory = $false, HelpMessage = "AD domain path that should have the organizational units for this deployment, eg OU=Hci001,OU=HciDeployments,DC=v,DC=masd,DC=stbtest,DC=microsoft,DC=com")]
        [string]$ADOUPath,

        [Parameter(Mandatory = $false, HelpMessage = "Fully qualified domain name used for this HCI deployment")]
        [string]$DomainFQDN,

        [Parameter(Mandatory = $false, HelpMessage = "HCI deployment prefix")]
        [string]
        $NamingPrefix,

        [Parameter(Mandatory = $true, HelpMessage = "Secure cluster name used by deployment (eg, s-cluster)")]
        [string]
        $ClusterName,

        [Parameter(Mandatory=$false, HelpMessage = "List of physical machines to validate are represented in AD.")]
        [array]
        $PhysicalMachineNames,

        [Parameter(Mandatory=$false, HelpMessage = "Name of the Active Directory server to use for AD queries.")]
        [string]
        $ActiveDirectoryServer = $null,

        [Parameter(Mandatory=$false, HelpMessage = "Credentials used to access the AD server for queries.")]
        [pscredential]
        $ActiveDirectoryCredentials = $null,

        [Parameter(Mandatory = $false, HelpMessage = "Specify the PsSession(s) used to validation from. If null the local machine will be used.")]
        [System.Management.Automation.Runspaces.PSSession[]]
        $PsSession,

        [Parameter(Mandatory = $false, HelpMessage = "Return PSObject result.")]
        [switch]
        $PassThru,

        [Parameter(Mandatory = $false, HelpMessage = "Hardware class: Small, Medium, or Large")]
        [ValidateSet('Small','Medium','Large')]
        [String]
        $HardwareClass = "Medium",

        [Parameter(Mandatory = $false, HelpMessage = "Cluster Pattern: Standard, Stretch, or RackAware")]
        [ValidateSet('Standard','Stretch','RackAware')]
        [String]
        $ClusterPattern = "Standard",

        [Parameter(Mandatory = $false, HelpMessage = "Operation type: Deployment, Upgrade, PreUpdate")]
        [ValidateSet('Deployment','Upgrade','PreUpdate')]
        [String]
        $OperationType = "Deployment",

        [Parameter(Mandatory = $false, HelpMessage = "Directory path for log and report output")]
        [string]$OutputPath,

        [Parameter(Mandatory = $false, HelpMessage = "Remove all previous progress and create a clean report")]
        [switch]$CleanReport = $false

    )

    try
    {
        $script:ErrorActionPreference = 'Stop'

        $diagnosticResults = @()
        Set-AzStackHciOutputPath -Path $OutputPath

        Write-AzStackHciHeader -invocation $MyInvocation -params $PSBoundParameters -PassThru:$PassThru
        Test-ModuleUpdate -PassThru:$PassThru

        # Test required inputs
        $ADOUPath = Get-ParamFromCommandLineOrConfigFile `
            -ConfigurationJsonPath "$ConfigurationJsonPath" `
            -ParameterName "ADOUPath" `
            -CommandLineParameterValue "$ADOUPath" `
            -ParameterDescription $lcAdTxt.ADOUPathDescription `
            -ValidationRegex '^(OU=[^,]+,)+(DC=[^,]+,)*DC=[^,]+$'

        # Only need to validate that it's not empty.  The user provides this and it's either valid, or it wouldn't have been created
        $DomainFQDN = Get-ParamFromCommandLineOrConfigFile `
            -ConfigurationJsonPath "$ConfigurationJsonPath" `
            -ParameterName "DomainFQDN" `
            -CommandLineParameterValue "$DomainFQDN" `
            -ParameterDescription $lcAdTxt.DomainFQDNDescription `
            -ValidationRegex '^.{1,255}$'

        # 1-8 characters, must start with a letter, not have more than one consecutive hyphen, and incude only letters, numbers, and hyphens
        $NamingPrefix = Get-ParamFromCommandLineOrConfigFile `
            -ConfigurationJsonPath "$ConfigurationJsonPath" `
            -ParameterName "NamingPrefix" `
            -CommandLineParameterValue "$NamingPrefix" `
            -ParameterDescription $lcAdTxt.NamingPrefixDescription `
            -ValidationRegex '^(?=.{1,8}$)([a-zA-Z])(\-?[a-zA-Z\d])*$'

        $ClusterName = Get-ClusterNameFromCommandLineOrConfigFile `
            -ConfigurationJsonPath "$ConfigurationJsonPath" `
            -CommandLineParameterValue "$ClusterName" `
            -ParameterDescription $lcAdTxt.ClusterNameDescription `
            -ValidationRegex '^((?!-)[A-Za-z0-9-]+(?<!-))$'

        $PhysicalMachineNames = Get-PhysicalHostNamesFromCommandLineOrConfigFile `
            -ConfigurationJsonPath "$ConfigurationJsonPath" `
            -CommandLineParameterValue $PhysicalMachineNames `
            -ParameterDescription $lcAdTxt.PhysicalMachineNamesDescription `
            -ValidationRegex '^[0-9a-z]([0-9a-z\-]{0,61}[0-9a-z])'

        # Ensure that the AD and GP modules are present
        Install-ActiveDirectoryModule
        Install-GroupPolicyModule

        # Call/Initialise reporting
        $envcheckerReport = Get-AzStackHciEnvProgress -clean:$CleanReport
        $envcheckerReport = Add-AzStackHciEnvJob -report $envcheckerReport


        if ($PsSession)
        {
            foreach ($Session in $PsSession)
            {
                if ($Session.State -ne 'Opened')
                {
                    try
                    {
                        Connect-PSSession -Session $Session
                    }
                    catch
                    {
                        $PsSessionFail = $lcTxt.PsSessionFail -f $Session.ComputerName, $_.Exception.Message
                        Log-Info ($PsSessionFail) -type Error
                        throw $PsSessionFail
                    }
                }
                $diagnosticResults += Test-OrganizationalUnit -ADOUPath $ADOUPath -DomainFQDN $DomainFQDN -NamingPrefix $NamingPrefix -ClusterName $ClusterName -PsSession $Session -ActiveDirectoryServer $ActiveDirectoryServer -ActiveDirectoryCredentials $ActiveDirectoryCredentials -PhysicalMachineNames $PhysicalMachineNames -OperationType $OperationType
            }
        }
        else
        {
            # Connectivity test follows this pattern, but I'm not sure this block is needed
            $diagnosticResults += Test-OrganizationalUnit -ADOUPath $ADOUPath -DomainFQDN $DomainFQDN -ClusterName $ClusterName -NamingPrefix $NamingPrefix -ActiveDirectoryServer $ActiveDirectoryServer -ActiveDirectoryCredentials $ActiveDirectoryCredentials -PhysicalMachineNames $PhysicalMachineNames -OperationType $OperationType
        }

        if (-not $PassThru)
        {
            Write-Host 'Active Directory Organizational Units Test Results'
            Write-AzStackHciResult -Title 'AD OU Diagnostics' -Result $diagnosticResults -seperator ': '
            Write-Summary -Result $diagnosticResults -Property1 Detail
        }
        else
        {
            return $diagnosticResults
        }
    }
    catch
    {
        Log-Info -Message "" -ConsoleOut
        Log-Info -Message "$($_.Exception.Message)" -ConsoleOut -Type Error
        Log-Info -Message "$($_.ScriptStackTrace)" -ConsoleOut -Type Error
        $cmdletException = $_
        throw $_
    }
    finally
    {
        $Script:ErrorActionPreference = 'SilentlyContinue'
        # Write result to telemetry channel
        foreach ($r in $diagnosticResults)
        {
            Write-ETWResult -Result $r
        }
        # Write validation result to report object and close out report
        $envcheckerReport | Add-Member -MemberType NoteProperty -Name 'AD OU Diagnostics' -Value $diagnosticResults -Force
        $envcheckerReport = Close-AzStackHciEnvJob -report $envcheckerReport
        Write-AzStackHciEnvReport -report $envcheckerReport
        Write-AzStackHciFooter -invocation $MyInvocation -Exception $cmdletException -PassThru:$PassThru
    }
}

